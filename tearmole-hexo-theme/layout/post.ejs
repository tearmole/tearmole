<article>
<header class="post-header">
<h1><%= page.title %></h1>
<div class="post-meta">
<time datetime="<%= date(page.date, 'YYYY-MM-DD') %>"><%= date(page.date, 'YYYY-MM-DD') %></time>
<% if (page.tags && page.tags.length) { %>
<span class="dot-sep"></span>
<div class="taglist" style="margin-top:0">
<% page.tags.each(function(tag) { %>
<a href="<%= url_for(tag.path) %>" class="tag"><%= tag.name %></a>
<% }) %>
</div>
<% } %>
</div>
</header>
<div class="post-body">
<%- page.content %>
</div>
</article>
